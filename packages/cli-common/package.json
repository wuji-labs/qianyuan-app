{
  "name": "@happier-dev/cli-common",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./links": {
      "types": "./dist/links.d.ts",
      "default": "./dist/links.js"
    },
    "./update": {
      "types": "./dist/update/index.d.ts",
      "default": "./dist/update/index.js"
    },
    "./workspaces": {
      "types": "./dist/workspaces/index.d.ts",
      "default": "./dist/workspaces/index.js"
    },
    "./service": {
      "types": "./dist/service/index.d.ts",
      "default": "./dist/service/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./providers/managedJavaScriptRuntime": {
      "types": "./dist/providers/managedJavaScriptRuntime.d.ts",
      "default": "./dist/providers/managedJavaScriptRuntime.js"
    },
    "./tailscale": {
      "types": "./dist/tailscale/index.d.ts",
      "default": "./dist/tailscale/index.js"
    },
    "./tailscale/taskContract": {
      "types": "./dist/tailscale/taskContract.d.ts",
      "default": "./dist/tailscale/taskContract.js"
    },
    "./process": {
      "types": "./dist/process/index.d.ts",
      "default": "./dist/process/index.js"
    },
    "./componentArtifacts": {
      "types": "./dist/componentArtifacts/index.d.ts",
      "default": "./dist/componentArtifacts/index.js"
    },
    "./output": {
      "types": "./dist/output/index.d.ts",
      "default": "./dist/output/index.js"
    },
    "./firstPartyRuntime": {
      "types": "./dist/firstPartyRuntime/index.d.ts",
      "default": "./dist/firstPartyRuntime/index.js"
    },
    "./relayHost": {
      "types": "./dist/relayHost/index.d.ts",
      "default": "./dist/relayHost/index.js"
    },
    "./systemTasks": {
      "types": "./dist/systemTasks/index.d.ts",
      "default": "./dist/systemTasks/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "postinstall:real": "yarn -s build",
    "postinstall": "node -e \"const fs=require('fs');const cp=require('child_process');if(/(^|[\\\\\\\\/])node_modules([\\\\\\\\/]|$)/i.test(process.cwd()))process.exit(0);try{const gate=require('../../scripts/postinstall/shouldRunPostinstall.cjs');if(!gate.shouldRunPostinstall({workspace:'cli-common',scope:process.env.HAPPIER_INSTALL_SCOPE||''}))process.exit(0);}catch{}if(!fs.existsSync('tsconfig.json'))process.exit(0);const run=(cmd,args)=>cp.spawnSync(cmd,args,{stdio:'inherit'});const npmExec=process.env.npm_execpath;let r;if(npmExec){r=run(process.execPath,[npmExec,'run','-s','postinstall:real']);}else{r=run(process.platform==='win32'?'yarn.cmd':'yarn',['-s','postinstall:real']);if(r.error&&process.platform==='win32'){r=run('yarn',['-s','postinstall:real']);}}if(r.error){console.error(r.error.message);process.exit(1);}process.exit(r.status??1);\"",
    "typecheck": "node ../../scripts/workspaces/runTypeScriptCli.mjs --noEmit -p tsconfig.json",
    "test": "yarn -s build && node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts"
  },
  "dependencies": {
    "@happier-dev/agents": "0.0.0",
    "@happier-dev/protocol": "0.0.0",
    "@happier-dev/release-runtime": "0.0.0"
  }
}
