{
  "name": "@happier-dev/release-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./minisign": {
      "types": "./dist/minisign.d.ts",
      "default": "./dist/minisign.js"
    },
    "./checksums": {
      "types": "./dist/checksums.d.ts",
      "default": "./dist/checksums.js"
    },
    "./assets": {
      "types": "./dist/assets.d.ts",
      "default": "./dist/assets.js"
    },
    "./extractPlan": {
      "types": "./dist/extractPlan.d.ts",
      "default": "./dist/extractPlan.js"
    },
    "./verifiedDownload": {
      "types": "./dist/verifiedDownload.d.ts",
      "default": "./dist/verifiedDownload.js"
    },
    "./github": {
      "types": "./dist/github.d.ts",
      "default": "./dist/github.js"
    },
    "./releaseRings": {
      "types": "./dist/releaseRings.d.ts",
      "require": "./releaseRings.cjs",
      "default": "./dist/releaseRings.js"
    }
  },
  "files": [
    "dist",
    "releaseRings.cjs",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build": "yarn -s build:esm",
    "test": "yarn -s build && HAPPIER_FEATURE_POLICY_ENV= node --test \"tests/*.test.mjs\"",
    "postinstall:real": "yarn -s build",
    "postinstall": "node -e \"const fs=require('fs');const cp=require('child_process');if(/(^|[\\\\\\\\/])node_modules([\\\\\\\\/]|$)/i.test(process.cwd()))process.exit(0);try{const gate=require('../../scripts/postinstall/shouldRunPostinstall.cjs');if(!gate.shouldRunPostinstall({workspace:'release-runtime',scope:process.env.HAPPIER_INSTALL_SCOPE||''}))process.exit(0);}catch{}if(!fs.existsSync('tsconfig.json'))process.exit(0);const run=(cmd,args)=>cp.spawnSync(cmd,args,{stdio:'inherit'});const npmExec=process.env.npm_execpath;let r;if(npmExec){r=run(process.execPath,[npmExec,'run','-s','postinstall:real']);}else{r=run(process.platform==='win32'?'yarn.cmd':'yarn',['-s','postinstall:real']);if(r.error&&process.platform==='win32'){r=run('yarn',['-s','postinstall:real']);}}if(r.error){console.error(r.error.message);process.exit(1);}process.exit(r.status??1);\""
  },
  "devDependencies": {
    "@types/node": ">=20",
    "typescript": "^5.9.2"
  }
}
