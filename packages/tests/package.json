{
  "name": "@happier-dev/tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node scripts/run-vitest-with-heartbeat.mjs --config vitest.core.config.ts",
    "test:core:fast": "node scripts/run-vitest-with-heartbeat.mjs --config vitest.core.fast.config.ts",
    "test:core:slow": "node scripts/run-vitest-with-heartbeat.mjs --config vitest.core.slow.config.ts",
    "test:stress": "node scripts/run-vitest-with-heartbeat.mjs --config vitest.stress.config.ts",
    "test:providers": "node scripts/run-vitest-with-heartbeat.mjs --config vitest.providers.config.ts",
    "test:ui:e2e": "playwright test -c playwright.ui.config.mjs",
    "typecheck": "tsc --noEmit",
    "providers:run": "node scripts/run-providers.mjs",
    "providers:run:parallel": "node scripts/run-providers-parallel.mjs",
    "providers:opencode:smoke": "yarn -s providers:run opencode smoke",
    "providers:opencode:extended": "yarn -s providers:run opencode extended",
    "providers:opencode_server:smoke": "yarn -s providers:run opencode_server smoke",
    "providers:opencode_server:extended": "yarn -s providers:run opencode_server extended",
    "providers:claude:smoke": "yarn -s providers:run claude smoke",
    "providers:claude:extended": "yarn -s providers:run claude extended",
    "providers:codex:smoke": "yarn -s providers:run codex smoke",
    "providers:codex:extended": "yarn -s providers:run codex extended",
    "providers:kilo:smoke": "yarn -s providers:run kilo smoke",
    "providers:kilo:extended": "yarn -s providers:run kilo extended",
    "providers:gemini:smoke": "yarn -s providers:run gemini smoke",
    "providers:gemini:extended": "yarn -s providers:run gemini extended",
    "providers:qwen:smoke": "yarn -s providers:run qwen smoke",
    "providers:qwen:extended": "yarn -s providers:run qwen extended",
    "providers:kimi:smoke": "yarn -s providers:run kimi smoke",
    "providers:kimi:extended": "yarn -s providers:run kimi extended",
    "providers:auggie:smoke": "yarn -s providers:run auggie smoke",
    "providers:auggie:extended": "yarn -s providers:run auggie extended",
    "providers:pi:smoke": "yarn -s providers:run pi smoke",
    "providers:pi:extended": "yarn -s providers:run pi extended",
    "providers:all:smoke": "yarn -s providers:run all smoke",
    "providers:all:extended": "yarn -s providers:run all extended",
    "providers:all:smoke:parallel": "yarn -s providers:run:parallel all smoke",
    "providers:all:extended:parallel": "yarn -s providers:run:parallel all extended",
    "providers:token-ledger:summary": "node scripts/provider-token-ledger-summary.mjs",
    "providers:opencode:smoke:update-baselines": "yarn -s providers:run opencode smoke --update-baselines",
    "providers:claude:smoke:update-baselines": "yarn -s providers:run claude smoke --update-baselines",
    "providers:codex:smoke:update-baselines": "yarn -s providers:run codex smoke --update-baselines",
    "providers:kilo:smoke:update-baselines": "yarn -s providers:run kilo smoke --update-baselines",
    "providers:gemini:smoke:update-baselines": "yarn -s providers:run gemini smoke --update-baselines",
    "providers:qwen:smoke:update-baselines": "yarn -s providers:run qwen smoke --update-baselines",
    "providers:kimi:smoke:update-baselines": "yarn -s providers:run kimi smoke --update-baselines",
    "providers:auggie:smoke:update-baselines": "yarn -s providers:run auggie smoke --update-baselines",
    "providers:pi:smoke:update-baselines": "yarn -s providers:run pi smoke --update-baselines"
  },
  "dependencies": {
    "@happier-dev/protocol": "0.0.0",
    "socket.io-client": "^4.8.1",
    "tweetnacl": "^1.0.3",
    "privacy-kit": "^0.0.25"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": ">=20",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
