{
  "name": "tailwind-prod-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "lint": "eslint \"src/**/*.{ts,tsx,js}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,css,json,md}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.2",
    "postcss": "^8.4.27",
    "autoprefixer": "^10.4.13",
    "vite": "^4.3.9"
  },
  "devDependencies": {
    "@types/react": "^18.2.9",
    "@types/react-dom": "^18.2.7",
    "typescript": "^5.2.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-react": "^7.34.0",
    "prettier": "^2.8.8",
    "husky": "^8.0.3",
    "lint-staged": "^13.1.0",
    "vitest": "^0.34.1",
    "jsdom": "^23.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": ["eslint --fix", "git add"],
    "*.{ts,tsx,js,css,md}": ["prettier --write", "git add"]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
