@@ -0,0 +1,205 @@
+import { createElement, type ReactNode } from 'react';
+import type { ASTNode, NodeType, RenderCapabilities } from './types';
+
+const COMPARISON_TEXT_NODE_TYPES: ReadonlySet<NodeType> = new Set([
+  'Text',
+  'Code',
+  'LatexMathInline',
+  'LatexMathDisplay',
+]);
+
+const NON_REVEALED_PARENT_TYPES: ReadonlySet<NodeType> = new Set([
+  'Code',
+  'CodeBlock',
+  'LatexMathInline',
+  'LatexMathDisplay',
+]);
+
+export interface StreamingRevealState {
+  activeRanges: readonly StreamingRevealRange[];
+}
+
+export interface StreamingRevealRange {
+  start: number;
+  end: number;
+  expiresAtMs: number;
+}
+
+export function readCommonPrefixLength(a: string, b: string): number {
+  const max = Math.min(a.length, b.length);
+  let index = 0;
+  while (index < max && a[index] === b[index]) {
+    index++;
+  }
+  return index;
+}
+
+export function readRenderedComparisonText(node: ASTNode | null): string {
+  if (!node) return '';
+
+  let text = COMPARISON_TEXT_NODE_TYPES.has(node.type) ? node.content ?? '' : '';
+  for (const child of node.children ?? []) {
+    text += readRenderedComparisonText(child);
+  }
+  return text;
+}
+
+export function markStreamingRevealOffsets(
+  node: ASTNode | null,
+  cursor: { current: number } = { current: 0 }
+): void {
+  if (!node) return;
+
+  if (COMPARISON_TEXT_NODE_TYPES.has(node.type)) {
+    node.streamingRevealStartOffset = cursor.current;
+    cursor.current += (node.content ?? '').length;
+  }
+
+  for (const child of node.children ?? []) {
+    markStreamingRevealOffsets(child, cursor);
+  }
+}
+
+export function createStreamingRevealState(params: Readonly<{
+  enabled: boolean;
+  activeRanges: readonly StreamingRevealRange[];
+}>): StreamingRevealState | null {
+  if (!params.enabled) return null;
+
+  return {
+    activeRanges: params.activeRanges,
+  };
+}
+
+function readRevealWordRanges(params: Readonly<{
+  text: string;
+  startOffset: number;
+  expiresAtMs: number;
+}>): StreamingRevealRange[] {
+  const ranges: StreamingRevealRange[] = [];
+  const wordPattern = /\S+/g;
+  let match: RegExpExecArray | null;
+
+  while ((match = wordPattern.exec(params.text)) != null) {
+    ranges.push({
+      start: params.startOffset + match.index,
+      end: params.startOffset + match.index + match[0].length,
+      expiresAtMs: params.expiresAtMs,
+    });
+  }
+
+  return ranges;
+}
+
+function mergeRevealRanges(
+  ranges: readonly StreamingRevealRange[]
+): StreamingRevealRange[] {
+  const sorted = [...ranges].sort((left, right) => {
+    if (left.start !== right.start) return left.start - right.start;
+    return left.end - right.end;
+  });
+  const merged: StreamingRevealRange[] = [];
+
+  for (const range of sorted) {
+    const previous = merged[merged.length - 1];
+    if (!previous || range.start > previous.end) {
+      merged.push(range);
+      continue;
+    }
+
+    merged[merged.length - 1] = {
+      start: previous.start,
+      end: Math.max(previous.end, range.end),
+      expiresAtMs: Math.max(previous.expiresAtMs, range.expiresAtMs),
+    };
+  }
+
+  return merged;
+}
+
+export function updateStreamingRevealRanges(params: Readonly<{
+  activeRanges: readonly StreamingRevealRange[];
+  previousComparisonText: string;
+  currentComparisonText: string;
+  nowMs: number;
+  ttlMs: number;
+}>): readonly StreamingRevealRange[] {
+  const retainedRanges = params.activeRanges.filter((range) =>
+    range.expiresAtMs > params.nowMs &&
+    range.start < params.currentComparisonText.length
+  ).map((range) => ({
+    ...range,
+    end: Math.min(range.end, params.currentComparisonText.length),
+  }));
+
+  const commonPrefixLength = readCommonPrefixLength(
+    params.previousComparisonText,
+    params.currentComparisonText
+  );
+  if (commonPrefixLength >= params.currentComparisonText.length) {
+    return mergeRevealRanges(retainedRanges);
+  }
+
+  return mergeRevealRanges([
+    ...retainedRanges,
+    ...readRevealWordRanges({
+      text: params.currentComparisonText.slice(commonPrefixLength),
+      startOffset: commonPrefixLength,
+      expiresAtMs: params.nowMs + params.ttlMs,
+    }),
+  ]);
+}
+
+export function shouldRevealTextForParent(parentType?: NodeType): boolean {
+  return parentType ? !NON_REVEALED_PARENT_TYPES.has(parentType) : true;
+}
+
+export function renderStreamingRevealText(params: Readonly<{
+  capabilities: RenderCapabilities;
+  text: string;
+  revealable: boolean;
+  startOffset: number;
+}>): ReactNode {
+  const reveal = params.capabilities.streamingReveal;
+  if (!reveal || !params.revealable) {
+    return params.text;
+  }
+
+  let cursor = params.startOffset;
+  let rangeIndex = 0;
+  const activeRanges = reveal.activeRanges;
+  const rendered = params.text
+    .split(/(\s+)/)
+    .filter((part) => part.length > 0)
+    .map((part, index) => {
+      const start = cursor;
+      const end = start + part.length;
+      cursor = end;
+
+      while (
+        rangeIndex < activeRanges.length &&
+        activeRanges[rangeIndex]!.end <= start
+      ) {
+        rangeIndex++;
+      }
+
+      const isActiveRevealRange =
+        rangeIndex < activeRanges.length &&
+        activeRanges[rangeIndex]!.start < end;
+
+      if (/^\s+$/.test(part) || !isActiveRevealRange) {
+        return part;
+      }
+
+      return createElement(
+        'span',
+        {
+          key: `${start}:${index}`,
+          'data-happier-enriched-markdown-reveal': 'text',
+        },
+        part
+      );
+    });
+
+  return rendered;
+}
