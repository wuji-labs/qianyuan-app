        "appleTeamId": "L86V3EF623",
        "ascApiKeyId": "58Q493BG53",
        "ascApiKeyIssuerId": "69a6de85-8d20-47e3-e053-5b8c7c11a4d1",
        "ascApiKeyPath": "./.eas/keys/AuthKey_58Q493BG53.p8"
      },
      "android": {
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "appleId": "leeroy.brun@gmail.com",
        "ascAppId": "6758554297",
        "appleTeamId": "L86V3EF623",
        "ascApiKeyId": "58Q493BG53",
        "ascApiKeyIssuerId": "69a6de85-8d20-47e3-e053-5b8c7c11a4d1",
        "ascApiKeyPath": "./.eas/keys/AuthKey_58Q493BG53.p8"
      },
      "android": {
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}
