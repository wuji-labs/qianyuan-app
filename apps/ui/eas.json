{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.14.0",
      "env": {
        "HAPPIER_INSTALL_SCOPE": "ui,protocol,agents",
        "EXPO_PUBLIC_HAPPY_SERVER_URL": "https://api.happier.dev",
        "HAPPIER_UI_VENDOR_WEB_ASSETS": "0"
      },
      "android": {
        "gradleCommand": ":app:bundleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      }
    },
    "development": {
      "extends": "base",
      "environment": "development",
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "APP_ENV": "development",
        "HAPPIER_EXPO_DEVCLIENT_LAUNCH_MODE": "most-recent",
        "HAPPIER_EXPO_DEVCLIENT_SILENT_LAUNCH": "true",
        "HAPPIER_EXPO_USE_NATIVE_DEBUG": "true",
        "EX_UPDATES_NATIVE_DEBUG": "1"
      }
    },
    "development-store": {
      "extends": "base",
      "environment": "development",
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "store",
      "channel": "development",
      "env": {
        "APP_ENV": "development"
      }
    },
    "canary": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "canary",
      "env": {
        "APP_ENV": "preview",
        "EXPO_UPDATES_CHANNEL": "canary",
        "EXPO_APP_NAME": "Happier (canary)",
        "EXPO_APP_BUNDLE_ID": "dev.happier.app.canary",
        "EXPO_APP_SCHEME": "happier-canary"
      }
    },
    "canary-apk": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "canary",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_UPDATES_CHANNEL": "canary",
        "EXPO_APP_NAME": "Happier (canary)",
        "EXPO_APP_BUNDLE_ID": "dev.happier.app.canary",
        "EXPO_APP_SCHEME": "happier-canary"
      }
    },
    "preview": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview"
      }
    },
    "preview-apk": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_ENV": "production"
      }
    },
    "production-preview": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "production",
        "HAPPIER_APP_VARIANT_OVERRIDE": "preview",
        "EXPO_UPDATES_CHANNEL": "preview",
        "EXPO_APP_BUNDLE_ID": "dev.happier.app"
      }
    },
    "production-apk": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "production",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "production"
      }
    },
    "production-preview-apk": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "production",
        "HAPPIER_APP_VARIANT_OVERRIDE": "preview",
        "EXPO_UPDATES_CHANNEL": "preview",
        "EXPO_APP_BUNDLE_ID": "dev.happier.app"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "leeroy.brun@gmail.com",
        "ascAppId": "6759219841",
        "appleTeamId": "L86V3EF623",
        "ascApiKeyId": "58Q493BG53",
        "ascApiKeyIssuerId": "69a6de85-8d20-47e3-e053-5b8c7c11a4d1",
        "ascApiKeyPath": "./.eas/keys/AuthKey_58Q493BG53.p8"
      },
      "android": {
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "appleId": "leeroy.brun@gmail.com",
        "ascAppId": "6758554297",
        "appleTeamId": "L86V3EF623",
        "ascApiKeyId": "58Q493BG53",
        "ascApiKeyIssuerId": "69a6de85-8d20-47e3-e053-5b8c7c11a4d1",
        "ascApiKeyPath": "./.eas/keys/AuthKey_58Q493BG53.p8"
      },
      "android": {
        "track": "production"
      }
    }
  }
}
