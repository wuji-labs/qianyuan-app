{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.14.0",
      "env": {
        "HAPPIER_EAS_ENSURE_UI_WORKSPACES_BUILT": "1",
        "HAPPIER_INSTALL_SCOPE": "ui,protocol,agents,cli-common,release-runtime,transfers,connection-supervisor",
        "YARN_PRODUCTION": "false",
        "npm_config_production": "false",
        "EXPO_PUBLIC_HAPPY_SERVER_URL": "http://192.168.8.112:3005",
        "HAPPIER_UI_VENDOR_WEB_ASSETS": "0",
        "EXPO_UNSTABLE_WEB_MODAL": "1"
      },
      "android": {
        "gradleCommand": ":app:bundleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      }
    },
    "internaldev": {
      "extends": "base",
      "environment": "development",
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "internaldev",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "APP_ENV": "internaldev",
        "EXPO_UPDATES_CHANNEL": "internaldev",
        "EXPO_APP_NAME": "乾元無極 (内部)",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan.dev.internal",
        "EXPO_ANDROID_PACKAGE": "com.wujilabs.qianyuan.internaldev",
        "EXPO_APP_SCHEME": "qianyuan-internaldev",
        "HAPPIER_EXPO_DEVCLIENT_LAUNCH_MODE": "most-recent",
        "HAPPIER_EXPO_DEVCLIENT_SILENT_LAUNCH": "true",
        "HAPPIER_EXPO_USE_NATIVE_DEBUG": "true",
        "EX_UPDATES_NATIVE_DEBUG": "1"
      }
    },
    "internaldev-dev-client": {
      "extends": "internaldev",
      "env": {
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan.dev.internal.devclient",
        "EXPO_ANDROID_PACKAGE": "com.wujilabs.qianyuan.internaldev.devclient",
        "EXPO_APP_SCHEME": "qianyuan-internaldev-devclient"
      }
    },
    "internaldev-store": {
      "extends": "base",
      "environment": "development",
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "store",
      "channel": "internaldev",
      "env": {
        "APP_ENV": "internaldev",
        "EXPO_UPDATES_CHANNEL": "internaldev",
        "EXPO_APP_NAME": "乾元無極 (内部)",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan.dev.internal",
        "EXPO_ANDROID_PACKAGE": "com.wujilabs.qianyuan.internaldev",
        "EXPO_APP_SCHEME": "qianyuan-internaldev"
      }
    },
    "internalpreview": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "internalpreview",
      "env": {
        "APP_ENV": "internalpreview",
        "EXPO_UPDATES_CHANNEL": "internalpreview",
        "EXPO_APP_NAME": "乾元無極 (内部预览)",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan.internalpreview",
        "EXPO_APP_SCHEME": "qianyuan-internalpreview"
      }
    },
    "internalpreview-apk": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "internalpreview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "internalpreview",
        "EXPO_UPDATES_CHANNEL": "internalpreview",
        "EXPO_APP_NAME": "乾元無極 (内部预览)",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan.internalpreview",
        "EXPO_APP_SCHEME": "qianyuan-internalpreview"
      }
    },
    "publicdev": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "store",
      "channel": "dev",
      "env": {
        "APP_ENV": "publicdev",
        "EXPO_UPDATES_CHANNEL": "dev",
        "EXPO_APP_NAME": "乾元無極 (dev)",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan.publicdev",
        "EXPO_APP_SCHEME": "qianyuan-dev"
      }
    },
    "publicdev-apk": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "dev",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "publicdev",
        "EXPO_UPDATES_CHANNEL": "dev",
        "EXPO_APP_NAME": "乾元無極 (dev)",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan.publicdev",
        "EXPO_APP_SCHEME": "qianyuan-dev",
        "HAPPIER_ANDROID_BUILD_ARCHS": "arm64-v8a",
        "HAPPIER_ANDROID_ENABLE_MINIFY": "1",
        "HAPPIER_ANDROID_ENABLE_SHRINK_RESOURCES": "1",
        "HAPPIER_ANDROID_GRADLE_JVMARGS": "-Xmx4096m -XX:MaxMetaspaceSize=1024m -Dfile.encoding=UTF-8"
      }
    },
    "publicdev-dev-client": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "dev",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "APP_ENV": "publicdev",
        "EXPO_UPDATES_CHANNEL": "dev",
        "EXPO_APP_NAME": "乾元無極 (dev)",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan.publicdev.devclient",
        "EXPO_ANDROID_PACKAGE": "com.wujilabs.qianyuan.publicdev.devclient",
        "EXPO_APP_SCHEME": "qianyuan-dev-devclient",
        "HAPPIER_EXPO_DEVCLIENT_LAUNCH_MODE": "most-recent",
        "HAPPIER_EXPO_DEVCLIENT_SILENT_LAUNCH": "true",
        "HAPPIER_EXPO_USE_NATIVE_DEBUG": "true",
        "EX_UPDATES_NATIVE_DEBUG": "1"
      }
    },
    "preview": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview"
      }
    },
    "preview-apk": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_ENV": "production"
      }
    },
    "production-preview": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "production",
        "HAPPIER_APP_VARIANT_OVERRIDE": "preview",
        "EXPO_UPDATES_CHANNEL": "preview",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan"
      }
    },
    "production-apk": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "production",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "production",
        "HAPPIER_ANDROID_BUILD_ARCHS": "arm64-v8a",
        "HAPPIER_ANDROID_ENABLE_MINIFY": "1",
        "HAPPIER_ANDROID_ENABLE_SHRINK_RESOURCES": "1",
        "HAPPIER_ANDROID_GRADLE_JVMARGS": "-Xmx4096m -XX:MaxMetaspaceSize=1024m -Dfile.encoding=UTF-8"
      }
    },
    "production-preview-apk": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      },
      "env": {
        "APP_ENV": "production",
        "HAPPIER_APP_VARIANT_OVERRIDE": "preview",
        "EXPO_UPDATES_CHANNEL": "preview",
        "EXPO_APP_BUNDLE_ID": "com.wujilabs.qianyuan",
        "HAPPIER_ANDROID_BUILD_ARCHS": "arm64-v8a",
        "HAPPIER_ANDROID_ENABLE_MINIFY": "1",
        "HAPPIER_ANDROID_ENABLE_SHRINK_RESOURCES": "1",
        "HAPPIER_ANDROID_GRADLE_JVMARGS": "-Xmx4096m -XX:MaxMetaspaceSize=1024m -Dfile.encoding=UTF-8"
      }
    },
    "development": {
      "extends": "internaldev"
    },
    "development-store": {
      "extends": "internaldev-store"
    },
    "canary": {
      "extends": "internalpreview"
    },
    "canary-apk": {
      "extends": "internalpreview-apk"
    }
  },
  "submit": {
    "publicdev": {
      "ios": {
        "appleId": "leeroy.brun@gmail.com",
        "ascAppId": "6761304097",
