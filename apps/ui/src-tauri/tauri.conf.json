{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Happier",
  "version": "0.2.7",
  "identifier": "dev.happier.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "node ./scripts/runTauriBeforeCommand.mjs tauri:prepare:dev",
    "beforeBuildCommand": "node ./scripts/runTauriBeforeCommand.mjs tauri:prepare:build"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "capabilities": [
        "default",
        "pet_overlay"
      ],
      "csp": null
    },
    "windows": [
      {
        "title": "Happier",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#F5F5F5",
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "externalBin": [
      "binaries/hsetup"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCRTk2MjE4RjNCMEYxRUYKUldUdjhiRHpHR0xwcTFIUjMvb1FBbW5HOUFYSkd5aGlHa204MWZuRk50ekF5WVZQdU1mVkRWWnkK",
      "endpoints": [
        "https://github.com/happier-dev/happier/releases/download/ui-desktop-stable/latest.json"
      ]
    }
  }
}
