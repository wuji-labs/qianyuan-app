{
  "name": "@happier-dev/server",
  "version": "0.1.2",
  "repository": "https://github.com/happier-dev/happier.git",
  "author": "Leeroy Brun <leeroy.brun@gmail.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build:shared": "node ./scripts/buildSharedDeps.mjs",
    "prebuild": "yarn -s build:shared",
    "pretest": "yarn -s build:shared && yarn -s schema:sync:check --quiet",
    "build": "tsc --noEmit",
    "typecheck": "yarn -s build",
    "start": "tsx ./sources/main.ts",
    "start:light": "tsx ./sources/main.light.ts",
    "dev": "tsx ./scripts/dev.full.ts",
    "dev:kill-port": "yarn dev -- --kill-port",
    "dev:light": "tsx ./scripts/dev.light.ts",
    "test": "yarn -s test:unit",
    "test:unit": "vitest run --isolate -c vitest.config.ts",
    "test:integration": "vitest run --isolate -c vitest.integration.config.ts",
    "test:db-contract": "vitest run --isolate -c vitest.dbcontract.config.ts",
    "test:server:db-contract": "yarn -s test:db-contract",
    "migrate": "dotenv -e .env.dev -- prisma migrate dev",
    "migrate:reset": "dotenv -e .env.dev -- prisma migrate reset",
    "migrate:light:deploy": "tsx ./scripts/migrate.light.deploy.ts",
    "migrate:sqlite:deploy": "tsx ./scripts/migrate.sqlite.deploy.ts",
    "migrate:mysql:deploy": "yarn -s schema:sync --quiet && prisma migrate deploy --schema prisma/mysql/schema.prisma",
    "migrate:light:resolve-baseline": "tsx ./scripts/migrate.light.resolveBaseline.ts",
    "migrate:light:new": "tsx ./scripts/migrate.light.new.ts",
    "schema:sync": "tsx ./scripts/schemaSync.ts",
    "schema:sync:check": "tsx ./scripts/schemaSync.ts --check",
    "generate": "prisma generate",
    "generate:light": "yarn -s schema:sync --quiet && prisma generate --schema prisma/sqlite/schema.prisma",
    "generate:mysql": "yarn -s schema:sync --quiet && prisma generate --schema prisma/mysql/schema.prisma",
    "generate:providers": "tsx ./scripts/generateClients.ts",
    "db:push:light": "yarn -s schema:sync --quiet && prisma db push --schema prisma/sqlite/schema.prisma",
    "postinstall:real": "yarn -s generate:providers && yarn -s build:shared",
    "postinstall": "node -e \"const fs=require('fs');const cp=require('child_process');if(/(^|[\\\\\\\\/])node_modules([\\\\\\\\/]|$)/i.test(process.cwd()))process.exit(0);try{const gate=require('../../scripts/postinstall/shouldRunPostinstall.cjs');if(!gate.shouldRunPostinstall({workspace:'server',scope:process.env.HAPPIER_INSTALL_SCOPE||''}))process.exit(0);}catch{}if(!fs.existsSync('scripts/schemaSync.ts'))process.exit(0);const run=(cmd,args)=>cp.spawnSync(cmd,args,{stdio:'inherit'});const npmExec=process.env.npm_execpath;let r;if(npmExec){r=run(process.execPath,[npmExec,'run','-s','postinstall:real']);}else{r=run(process.platform==='win32'?'yarn.cmd':'yarn',['-s','postinstall:real']);if(r.error&&process.platform==='win32'){r=run('yarn',['-s','postinstall:real']);}}if(r.error){console.error(r.error.message);process.exit(1);}process.exit(r.status??1);\"",
    "db": "docker run -d -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=handy -v $(pwd)/.pgdata:/var/lib/postgresql/data -p 5432:5432 postgres:17",
    "redis": "docker run -d -p 6379:6379 redis",
    "s3": "docker run -d --name minio -p 9000:9000 -p 9001:9001 -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin -v $(pwd)/.minio/data:/data minio/minio server /data --console-address :9001",
    "s3:down": "docker rm -f minio || true",
    "s3:init": "dotenv -e .env.dev -- sh -c 'docker run --rm --network container:minio --entrypoint /bin/sh -e S3_ACCESS_KEY -e S3_SECRET_KEY -e S3_BUCKET minio/mc -c \"mc alias set local http://localhost:9000 \\$S3_ACCESS_KEY \\$S3_SECRET_KEY && mc mb -p local/\\$S3_BUCKET || true && mc anonymous set download local/\\$S3_BUCKET\"'",
    "validate:redis-adapter": "tsx ./scripts/validate.redisAdapterFanout.ts"
  },
  "devDependencies": {
    "@types/chalk": "^2.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.3",
    "@types/tmp": "^0.2.6",
    "@types/uuid": "^9.0.8",
    "dotenv-cli": "^8.0.0",
    "redis-memory-server": "^0.16.0",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "yaml": "^2.4.2"
  },
  "dependencies": {
    "@date-fns/tz": "^1.2.0",
    "@electric-sql/pglite": "^0.3.15",
    "@electric-sql/pglite-socket": "^0.0.20",
    "@fastify/bearer-auth": "^10.1.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "9.7.0",
    "@happier-dev/agents": "0.0.0",
    "@happier-dev/protocol": "0.0.0",
    "@prisma/client": "^6.11.1",
    "@socket.io/redis-streams-adapter": "^0.2.2",
    "@sentry/profiling-node": "^10.39.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/semver": "^7.7.0",
    "axios": "^1.6.8",
    "chalk": "4.1.2",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "elevenlabs": "^1.54.0",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "6.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.5",
    "octokit": "^5.0.3",
    "openapi-types": "12.1.3",
    "openid-client": "^6.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.11.1",
    "prisma-json-types-generator": "^3.5.1",
    "privacy-kit": "^0.0.25",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.7.2",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.1",
    "socket.io-adapter": "^2.5.5",
    "@sentry/node": "10.39.0",
    "tmp": "^0.2.3",
    "tsx": "^4.19.2",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.0",
    "zod": "4.3.6",
    "zod-to-json-schema": "^3.24.3"
  }
}
